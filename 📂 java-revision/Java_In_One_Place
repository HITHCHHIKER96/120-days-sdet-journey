import java.util.*;
import java.util.stream.*;

List<Integer> numbers = List.of(1, 2, 3, 4, 5, 6, 7, 8);

// Get sum of all even numbers, doubled
int result = numbers.stream()
    .filter(n -> n % 2 == 0)       // keep only evens: 2,4,6,8
    .map(n -> n * 2)               // double each: 4,8,12,16
    .reduce(0, Integer::sum);       // sum all: 40

// Collect to a new list
List<String> names = List.of("alice", "bob", "charlie");

List<String> upper = names.stream()
    .filter(n -> n.length() > 3)       // alice, charlie
    .map(String::toUpperCase)            // ALICE, CHARLIE
    .sorted()                            // ALICE, CHARLIE (already sorted)
    .collect(Collectors.toList());
